    },
    {
      "name": "people",
      "type": "discussion_event",
      "id": "https://mastodon.social/@pahlkadot/112003396313784951",
      "title": "<p>I'm writing on Substack now, and I'd love it if you'd subscribe! My first post talks about \"I-95-ness\" and how it might play out in the election.<br><a href=\"https://eatingpolicy.substack.com/p/the-public-wants-i-95-ness?open=false\" rel=\"noopener noreferrer\"><span>https://</span><span>eatingpolicy.substack.com/p/th</span><span>e-public-wants-i-95-ness?open=false</span></a></p>",
      "link": "https://mastodon.social/@pahlkadot/112003396313784951",
      "updated": "2024-02-27T12:16:38Z",
      "image": "https://files.mastodon.social/accounts/avatars/109/252/092/189/918/292/original/d010861728a38beb.jpg"
    },
